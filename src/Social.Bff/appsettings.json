{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "Identity": "http://localhost:5101/"
  },
  "ReverseProxy": {
    "Routes": {
      "social-follows": {
        "ClusterId": "social",
        "Order": 1,
        "Match": { "Path": "/api/users/{userId}/follows" }
      },
      "social-counts": {
        "ClusterId": "social",
        "Order": 2,
        "Match": { "Path": "/api/users/{userId}/counts" }
      },
      "engagement-likes": {
        "ClusterId": "engagement",
        "Order": 3,
        "Match": { "Path": "/api/posts/{postId}/likes" }
      },
      "engagement-comments": {
        "ClusterId": "engagement",
        "Order": 4,
        "Match": { "Path": "/api/posts/{postId}/comments/{**rest}" }
      },
      "engagement-comments-root": {
        "ClusterId": "engagement",
        "Order": 4,
        "Match": { "Path": "/api/posts/{postId}/comments" }
      },
      "posts": {
        "ClusterId": "post",
        "Order": 5,
        "Match": { "Path": "/api/posts/{**rest}" }
      },
      "feed": {
        "ClusterId": "feed",
        "Order": 6,
        "Match": { "Path": "/api/feed/{**rest}" }
      },
      "identity": {
        "ClusterId": "identity",
        "Order": 7,
        "Match": { "Path": "/api/{**rest}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5101/" }
        }
      },
      "post": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5102/" }
        }
      },
      "social": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5103/" }
        }
      },
      "engagement": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5104/" }
        }
      },
      "feed": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5105/" }
        }
      }
    }
  }
}
