@page "/login"
@inject ApiClient Api
@inject AppSession Session
@inject NavigationManager Nav

<section class="auth">
    <div class="auth-panel">
        <h1>Log in</h1>
        <p>Use your registered email and password.</p>
        <input @bind="_email" placeholder="Email" type="email" />
        <input @bind="_password" placeholder="Password" type="password" />
        <button disabled="@_busy" @onclick="LoginAsync">Log in</button>
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="field-message">@_error</p>
        }
        <p class="switch">Forgot your password? <a href="/forgot-password">Reset it</a></p>
        <p class="switch">Need an account? <a href="/register">Register</a></p>
    </div>
</section>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _busy;

    private async Task LoginAsync()
    {
        _busy = true;
        _error = null;
        var (user, error) = await Api.LoginAsync(_email, _password);
        if (error is not null)
        {
            _error = error;
            _busy = false;
            return;
        }
        Session.Apply(user!);
        Nav.NavigateTo("/", forceLoad: true);
    }
}
