@page "/reset-password"
@rendermode InteractiveServer
@inject Social.Web.Services.AuthApi Auth
@inject NavigationManager Nav

<section class="auth">
    <div class="auth-panel">
        <h1>Reset password</h1>
        @if (_success)
        {
            <p>Password updated. <a href="/login">Log in</a> with your new password.</p>
        }
        else
        {
            <input @bind="_password" placeholder="New password" type="password" />
            <input @bind="_confirm" placeholder="Confirm new password" type="password" />
            <button @onclick="ResetAsync">Set new password</button>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="field-message">@_error</p>
            }
        }
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string _password = "";
    private string _confirm = "";
    private string? _error;
    private bool _success;

    private async Task ResetAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            _error = "Invalid reset link.";
            return;
        }
        if (_password != _confirm)
        {
            _error = "Passwords do not match.";
            return;
        }
        _error = await Auth.ResetPasswordAsync(Token, _password);
        if (_error is null) _success = true;
    }
}
