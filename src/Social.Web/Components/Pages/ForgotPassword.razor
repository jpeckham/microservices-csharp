@page "/forgot-password"
@rendermode InteractiveServer
@inject Social.Web.Services.AuthApi Auth

<section class="auth">
    <div class="auth-panel">
        <h1>Forgot password</h1>
        @if (_sent)
        {
            <p>If that email is registered, you'll receive a reset link shortly.</p>
            <p class="switch"><a href="/login">Back to log in</a></p>
        }
        else
        {
            <p>Enter your email and we'll send you a reset link.</p>
            <input @bind="_email" placeholder="Email" type="email" />
            <button @onclick="SendAsync">Send reset link</button>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="field-message">@_error</p>
            }
            <p class="switch"><a href="/login">Back to log in</a></p>
        }
    </div>
</section>

@code {
    private string _email = "";
    private string? _error;
    private bool _sent;

    private async Task SendAsync()
    {
        _error = await Auth.RequestPasswordResetAsync(_email);
        if (_error is null) _sent = true;
    }
}
