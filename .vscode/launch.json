{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Everything (Docker Compose)",
      "type": "node-terminal",
      "request": "launch",
      "command": "docker compose up --build --remove-orphans",
      "cwd": "${workspaceFolder}",
      "postDebugTask": "docker-compose-down",
      "serverReadyAction": {
        "pattern": "social-bff.*Now listening on",
        "uriFormat": "http://localhost:32123",
        "action": "openExternally"
      }
    }
  ]
}
